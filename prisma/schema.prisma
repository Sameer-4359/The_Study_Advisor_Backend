// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  fullName         String
  email            String        @unique
  password         String
  role             String?       @default("student")
  createdAt        DateTime      @default(now())
  documents        Document[]
  userProfile      UserProfile?  // Relation defined on UserProfile side
  sopVersions      StatementOfPurpose[]      @relation("StudentSops")
  reviewedSops     StatementOfPurpose[]      @relation("SopReviewer")
  sopComments      SOPReviewComment[]
  activityEvents   StudentActivityEvent[]    @relation("StudentActivity")
  activityActors   StudentActivityEvent[]    @relation("ActivityActor")
  counselorNotifications CounselorNotification[] @relation("CounselorNotifications")
  studentNotifications   CounselorNotification[] @relation("StudentNotifications")
  counselorProfile CounselorProfile?
  counselorAssignments CounselorStudentAssignment[] @relation("CounselorAssignments")
  studentAssignment CounselorStudentAssignment[] @relation("StudentAssignments")
  createdAssignments CounselorStudentAssignment[] @relation("AssignmentCreatedBy")
}

model Document {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       DocumentType
  fileUrl    String
  fileName   String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  sopVersions StatementOfPurpose[]
}

model UserProfile {
  id                     Int       @id @default(autoincrement())
  userId                 Int       @unique
  user                   User      @relation(fields: [userId], references: [id])
  
  // Personal Information
  firstName              String?
  lastName               String?
  phoneNumber            String?
  dateOfBirth            DateTime?
  nationality            String?
  gender                 String?
  
  // Academic Information
  currentEducationLevel  EducationLevel?
  institutionName        String?
  fieldOfStudy           String?
  ieltsScore             Float?
  cgpa                   Float?
  academicYear           Int?
  
  // Study Preferences
  desiredProgram         String?
  preferredCountry       String?
  budgetRangeMin         Int?
  budgetRangeMax         Int?
  preferredIntake        String?
  studyMode              StudyMode?
  
  // Additional Info
  workExperience         Int?     // in years
  researchExperience     Boolean? @default(false)
  publications           Int?     @default(0)
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model StatementOfPurpose {
  id             Int       @id @default(autoincrement())
  userId         Int
  documentId     Int?
  version        Int
  title          String?
  content        String?
  status         SOPStatus @default(DRAFT)
  reviewNotes    String?
  reviewedBy     Int?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation("StudentSops", fields: [userId], references: [id], onDelete: Cascade)
  document       Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  reviewer       User?     @relation("SopReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  comments       SOPReviewComment[]

  @@unique([userId, version])
  @@index([userId, status, createdAt])
}

model SOPReviewComment {
  id             Int       @id @default(autoincrement())
  sopId          Int
  authorId       Int
  body           String
  createdAt      DateTime  @default(now())

  sop            StatementOfPurpose @relation(fields: [sopId], references: [id], onDelete: Cascade)
  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sopId, createdAt])
}

model StudentActivityEvent {
  id             Int       @id @default(autoincrement())
  studentId      Int
  actorId        Int?
  eventType      ActivityEventType
  description    String
  metadata       Json?
  createdAt      DateTime  @default(now())

  student        User      @relation("StudentActivity", fields: [studentId], references: [id], onDelete: Cascade)
  actor          User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  notifications  CounselorNotification[]

  @@index([studentId, createdAt])
  @@index([eventType, createdAt])
}

model CounselorNotification {
  id             Int       @id @default(autoincrement())
  counselorId    Int
  studentId      Int?
  activityEventId Int?
  type           NotificationType
  title          String
  message        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  counselor      User      @relation("CounselorNotifications", fields: [counselorId], references: [id], onDelete: Cascade)
  student        User?     @relation("StudentNotifications", fields: [studentId], references: [id], onDelete: SetNull)
  activityEvent  StudentActivityEvent? @relation(fields: [activityEventId], references: [id], onDelete: SetNull)

  @@index([counselorId, isRead, createdAt])
  @@index([studentId, createdAt])
}

model CounselorProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  phone      String?
  capacity   Int      @default(20)
  skills     String[] @default([])
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CounselorStudentAssignment {
  id          Int      @id @default(autoincrement())
  counselorId Int
  studentId   Int      @unique
  assignedBy  Int?
  notes       String?
  status      String   @default("ACTIVE")
  assignedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  counselor   User     @relation("CounselorAssignments", fields: [counselorId], references: [id], onDelete: Cascade)
  student     User     @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  creator     User?    @relation("AssignmentCreatedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([counselorId, status])
  @@index([studentId, status])
}

enum DocumentType {
  ACADEMIC_TRANSCRIPT
  DEGREE_DIPLOMA
  LANGUAGE_PROFICIENCY
  PASSPORT_COPY
  RESUME_CV
  STATEMENT_OF_PURPOSE
}

enum EducationLevel {
  HIGH_SCHOOL
  BACHELORS
  MASTERS
  PHD
  POST_DOCTORAL
}

enum StudyMode {
  FULL_TIME
  PART_TIME
  ONLINE
  HYBRID
}

enum SOPStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
}

enum ActivityEventType {
  PROFILE_UPDATED
  DOCUMENT_UPLOADED
  DOCUMENT_UPDATED
  DOCUMENT_DELETED
  SOP_DRAFT_SAVED
  SOP_SUBMITTED
  SOP_REVIEWED
}

enum NotificationType {
  PROFILE
  DOCUMENT
  SOP
  SYSTEM
}